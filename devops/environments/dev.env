# ============================
# WOLLOYEWA STORE BOT - DEVELOPMENT ENVIRONMENT
# ============================

# Application Core
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=dev-secret-key-change-in-production
PROJECT_NAME=Wolloyewa_Store_Bot
TIMEZONE=Africa/Addis_Ababa
HOST=0.0.0.0
PORT=8000

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=welloyewadb
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_dev_bot_token
TELEGRAM_WEBHOOK_URL=https://your-ngrok-url.ngrok.io
TELEGRAM_WEBHOOK_SECRET=dev_webhook_secret
ADMIN_IDS=123456789,987654321

# Payment Gateways (Test Keys)
CHAPA_SECRET_KEY=chapa_test_secret_key
CHAPA_WEBHOOK_SECRET=chapa_webhook_secret
TELEBIRR_APP_ID=test_app_id
TELEBIRR_APP_KEY=test_app_key
CBE_BIRR_MERCHANT_ID=test_merchant_id

# Storage
STORAGE_PROVIDER=local
STORAGE_BASE_URL=http://localhost:8000

# Email (Development - MailHog)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=dev@wolloyewa.com

# SMS (Test Mode)
SMS_PROVIDER=test
SMS_API_KEY=test_key
SMS_SENDER_ID=WOLLOYEWA

# Feature Flags
ENABLE_PUSH_NOTIFICATIONS=False
ENABLE_WEB_APP=True
ENABLE_AI_SUPPORT_BOT=False
ENABLE_LOYALTY_PROGRAM=True
ENABLE_ESCROW_SERVICE=False
ENABLE_AB_TESTING=True

# Rate Limiting (Less strict in dev)
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_PER_HOUR=2000

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=text
LOG_FILE_PATH=./logs/dev.log

# Development specific
DEV_FAKE_PAYMENT=True
DEV_POPULATE_DUMMY_DATA=True
DEV_SKIP_MIDDLEWARES=False
DEV_AUTO_CREATE_SCHEMA=True

# Monitoring (Disabled in dev)
PROMETHEUS_ENABLED=False
SENTRY_DSN=
OTEL_TRACING_ENABLED=False

# Celery (Eager mode for dev)
CELERY_TASK_ALWAYS_EAGER=True
CELERY_WORKER_CONCURRENCY=2
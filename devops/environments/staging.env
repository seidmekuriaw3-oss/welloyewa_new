# ============================
# WOLLOYEWA STORE BOT - STAGING ENVIRONMENT
# ============================

# Application Core
ENVIRONMENT=staging
DEBUG=False
SECRET_KEY=${STAGING_SECRET_KEY}
PROJECT_NAME=Wolloyewa_Store_Bot
TIMEZONE=Africa/Addis_Ababa
HOST=0.0.0.0
PORT=8000

# Database
POSTGRES_USER=wolloyewa_user
POSTGRES_PASSWORD=${STAGING_DB_PASSWORD}
POSTGRES_DB=welloyewadb
POSTGRES_HOST=postgres-staging.internal
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Redis
REDIS_HOST=redis-staging.internal
REDIS_PORT=6379
REDIS_PASSWORD=${STAGING_REDIS_PASSWORD}
REDIS_DB=0
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# Telegram Bot
TELEGRAM_BOT_TOKEN=${STAGING_TELEGRAM_BOT_TOKEN}
TELEGRAM_WEBHOOK_URL=https://staging-api.wolloyewa.com/webhook
TELEGRAM_WEBHOOK_SECRET=${STAGING_WEBHOOK_SECRET}
ADMIN_IDS=${STAGING_ADMIN_IDS}

# Payment Gateways (Staging Keys)
CHAPA_SECRET_KEY=${STAGING_CHAPA_SECRET}
CHAPA_WEBHOOK_SECRET=${STAGING_CHAPA_WEBHOOK}
TELEBIRR_APP_ID=${STAGING_TELEBIRR_APP_ID}
TELEBIRR_APP_KEY=${STAGING_TELEBIRR_APP_KEY}
CBE_BIRR_MERCHANT_ID=${STAGING_CBE_MERCHANT_ID}

# Storage (S3 for staging)
STORAGE_PROVIDER=s3
STORAGE_BASE_URL=https://cdn-staging.wolloyewa.com
AWS_ACCESS_KEY_ID=${STAGING_AWS_ACCESS_KEY}
AWS_SECRET_ACCESS_KEY=${STAGING_AWS_SECRET_KEY}
AWS_S3_BUCKET_NAME=wolloyewa-staging
AWS_REGION=eu-north-1

# Email (SendGrid for staging)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=${STAGING_SENDGRID_KEY}
EMAIL_FROM=noreply@staging.wolloyewa.com

# SMS (African's Talking)
SMS_PROVIDER=african_talking
SMS_API_KEY=${STAGING_AFRICASTALKING_KEY}
SMS_SENDER_ID=WOLLOYEWA

# Feature Flags
ENABLE_PUSH_NOTIFICATIONS=True
ENABLE_WEB_APP=True
ENABLE_AI_SUPPORT_BOT=True
ENABLE_LOYALTY_PROGRAM=True
ENABLE_ESCROW_SERVICE=True
ENABLE_AB_TESTING=True

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=/var/log/wolloyewa/staging.log

# Monitoring
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090
SENTRY_DSN=${STAGING_SENTRY_DSN}
OTEL_TRACING_ENABLED=True
OTEL_EXPORTER_ENDPOINT=http://jaeger-staging:14268/api/traces

# Celery
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}
CELERY_TASK_ALWAYS_EAGER=False
CELERY_WORKER_CONCURRENCY=4

# Security
JWT_SECRET_KEY=${STAGING_JWT_SECRET}
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440
CORS_ALLOWED_ORIGINS=https://staging.wolloyewa.com,https://staging-api.wolloyewa.com
ENCRYPTION_KEY=${STAGING_ENCRYPTION_KEY}

# Backup
BACKUP_ENABLED=True
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7
BACKUP_STORAGE_PATH=/backups

# Session Limits
MAX_ACTIVE_SESSIONS=100
MAX_IDLE_SESSIONS=50
SESSION_TIMEOUT_MINUTES=30

# Staging specific
STAGING_MODE=True
FAKE_PAYMENT=False
SKIP_MIDDLEWARES=False
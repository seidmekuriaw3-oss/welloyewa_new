# ============================
# WOLLOYEWA STORE BOT - PRODUCTION ENVIRONMENT
# ============================

# Application Core
ENVIRONMENT=production
DEBUG=False
SECRET_KEY=${PROD_SECRET_KEY}
PROJECT_NAME=Wolloyewa_Store_Bot
TIMEZONE=Africa/Addis_Ababa
HOST=0.0.0.0
PORT=8000

# Database (Primary + Replica)
POSTGRES_USER=wolloyewa_user
POSTGRES_PASSWORD=${PROD_DB_PASSWORD}
POSTGRES_DB=welloyewadb
POSTGRES_HOST=postgres-primary.internal
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_REPLICA_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres-replica.internal:5432/${POSTGRES_DB}
DATABASE_POOL_SIZE=50
DATABASE_MAX_OVERFLOW=100
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600
DATABASE_POOL_PRE_PING=true

# Redis (Cluster)
REDIS_HOST=redis-cluster.internal
REDIS_PORT=6379
REDIS_PASSWORD=${PROD_REDIS_PASSWORD}
REDIS_DB=0
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}
REDIS_CACHE_TTL=3600
REDIS_SESSION_TTL=86400

# Telegram Bot
TELEGRAM_BOT_TOKEN=${PROD_TELEGRAM_BOT_TOKEN}
TELEGRAM_WEBHOOK_URL=https://api.wolloyewa.com/webhook
TELEGRAM_WEBHOOK_SECRET=${PROD_WEBHOOK_SECRET}
ADMIN_IDS=${PROD_ADMIN_IDS}

# Payment Gateways (Production Keys)
CHAPA_SECRET_KEY=${PROD_CHAPA_SECRET}
CHAPA_WEBHOOK_SECRET=${PROD_CHAPA_WEBHOOK}
TELEBIRR_APP_ID=${PROD_TELEBIRR_APP_ID}
TELEBIRR_APP_KEY=${PROD_TELEBIRR_APP_KEY}
TELEBIRR_SHORT_CODE=12345
CBE_BIRR_MERCHANT_ID=${PROD_CBE_MERCHANT_ID}
CBE_BIRR_TERMINAL_ID=${PROD_CBE_TERMINAL_ID}
CBE_BIRR_SECRET_KEY=${PROD_CBE_SECRET}

# Storage (CloudFront + S3)
STORAGE_PROVIDER=s3
STORAGE_BASE_URL=https://cdn.wolloyewa.com
CLOUDINARY_CLOUD_NAME=${PROD_CLOUDINARY_NAME}
CLOUDINARY_API_KEY=${PROD_CLOUDINARY_KEY}
CLOUDINARY_API_SECRET=${PROD_CLOUDINARY_SECRET}
AWS_ACCESS_KEY_ID=${PROD_AWS_ACCESS_KEY}
AWS_SECRET_ACCESS_KEY=${PROD_AWS_SECRET_KEY}
AWS_S3_BUCKET_NAME=wolloyewa-prod
AWS_REGION=eu-north-1

# Email (Amazon SES)
SMTP_HOST=email-smtp.eu-north-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=${PROD_SES_USER}
SMTP_PASSWORD=${PROD_SES_PASSWORD}
EMAIL_FROM=noreply@wolloyewa.com

# SMS (Ethio Telecom)
SMS_PROVIDER=ethio_telecom
SMS_API_KEY=${PROD_ETHIOTELECOM_KEY}
SMS_SENDER_ID=WOLLOYEWA

# Feature Flags
ENABLE_PUSH_NOTIFICATIONS=True
ENABLE_WEB_APP=True
ENABLE_AI_SUPPORT_BOT=True
ENABLE_LOYALTY_PROGRAM=True
ENABLE_ESCROW_SERVICE=True
ENABLE_AB_TESTING=True

# Rate Limiting (Strict)
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_STRATEGY=sliding_window

# Security
JWT_SECRET_KEY=${PROD_JWT_SECRET}
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440
CORS_ALLOWED_ORIGINS=https://wolloyewa.com,https://api.wolloyewa.com,https://admin.wolloyewa.com
ENCRYPTION_KEY=${PROD_ENCRYPTION_KEY}
GDPR_COMPLIANT=True
DATA_RETENTION_DAYS=365
AUDIT_LOG_ENABLED=True

# Logging
LOG_LEVEL=WARNING
LOG_FORMAT=json
LOG_FILE_PATH=/var/log/wolloyewa/prod.log
LOG_ELASTICSEARCH_HOST=elasticsearch.internal:9200

# Monitoring
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090
GRAFANA_ENABLED=True
SENTRY_DSN=${PROD_SENTRY_DSN}
OTEL_TRACING_ENABLED=True
OTEL_EXPORTER_ENDPOINT=http://jaeger.internal:14268/api/traces

# Celery
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}
CELERY_TASK_ALWAYS_EAGER=False
CELERY_WORKER_CONCURRENCY=8

# Backup
BACKUP_ENABLED=True
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/backups
BACKUP_S3_BUCKET=wolloyewa-backups

# Session Limits
MAX_ACTIVE_SESSIONS=1000
MAX_IDLE_SESSIONS=500
SESSION_TIMEOUT_MINUTES=30
TRANSACTIONS_PER_SECOND_ACTIVE=50
TRANSACTIONS_PER_SECOND_IDLE=10

# Production specific
PRODUCTION_MODE=True
FAKE_PAYMENT=False
SKIP_MIDDLEWARES=False
MAINTENANCE_MODE=False

# Health Checks
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
READINESS_CHECK_PATH=/health/ready
LIVENESS_CHECK_PATH=/health/live

# SSL/TLS
SSL_CERT_PATH=/etc/ssl/certs/wolloyewa.crt
SSL_KEY_PATH=/etc/ssl/private/wolloyewa.key

# Multi-tenancy
MULTI_TENANT_ENABLED=True
DEFAULT_TENANT_ID=public

# External Services
GOOGLE_MAPS_API_KEY=${PROD_GOOGLE_MAPS_KEY}
ETHIOPIAN_HOLIDAYS_API=https://api.ethiopianholidays.com/v1

# CDN
CDN_ENABLED=True
CDN_URL=https://cdn.wolloyewa.com
CDN_PURGE_KEY=${PROD_CDN_PURGE_KEY}

# WebSocket
WEBSOCKET_ENABLED=True
WEBSOCKET_PATH=/ws
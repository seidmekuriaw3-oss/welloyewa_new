# ============================
# WOLLOYEWA STORE BOT - ENVIRONMENT VARIABLES
# ============================
# ጠቃሚ ማስታወሻ: ይህንን መረጃ .env በሚል ፋይል ሴቭ አድርገው በፕሮጀክትዎ ስር ያስቀድሙ።
# .env ፋይል ሚስጥራዊ ስለሆነ Git ላይ እንዳይጫን (ignore መደረጉን) ያረጋግጡ።

# ============================
# APPLICATION CORE
# ============================
ENVIRONMENT=development              # development / staging / production
DEBUG=True
SECRET_KEY="change-this-in-production-minimum-32-chars"
PROJECT_NAME="Wolloyewa_Store_Bot"
TIMEZONE="Africa/Addis_Ababa"

# ============================
# DATABASE (ሙሉ በሙሉ በፈለጉት ስም የተስተካከለ)
# ============================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=%4099Nameallah # <-- እዚህ ላይ የ PostgreSQL የይለፍ ቃልዎን ያስገቡ
POSTGRES_DB=welloyewanewdb                             # <-- አሁን በአዲስ የተፈጠረው ንጹህ ዳታቤዝ ስም
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/welloyewanewdb
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ============================
# REDIS (Cache & Queue)
# ============================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}
REDIS_CACHE_TTL=3600
REDIS_SESSION_TTL=86400

# ============================
# TELEGRAM BOT
# ============================
TELEGRAM_BOT_TOKEN="your_bot_token_from_botfather"
TELEGRAM_WEBHOOK_URL="https://your-domain.com/webhook"
TELEGRAM_WEBHOOK_SECRET="your-webhook-secret-token"
ADMIN_IDS="123456789,987654321"

# ============================
# PAYMENT GATEWAYS (Ethiopia)
# ============================

# Chapa
CHAPA_SECRET_KEY="your_chapa_secret_key"
CHAPA_WEBHOOK_SECRET="your_chapa_webhook_secret"
CHAPA_API_URL="https://api.chapa.co/v1"

# Telebirr
TELEBIRR_APP_ID="your_telebirr_app_id"
TELEBIRR_APP_KEY="your_telebirr_app_key"
TELEBIRR_SHORT_CODE="12345"
TELEBIRR_API_URL="https://api.ethiotelecom.et/telebirr"

# CBE Birr
CBE_BIRR_MERCHANT_ID="your_merchant_id"
CBE_BIRR_TERMINAL_ID="your_terminal_id"
CBE_BIRR_SECRET_KEY="your_cbe_secret_key"
CBE_BIRR_API_URL="https://cbe-birr.api"

# ============================
# STORAGE (Images/Documents)
# ============================
STORAGE_PROVIDER=local               # local / s3 / cloudinary
STORAGE_BASE_URL="http://localhost:8000"
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET_NAME="wolloyewa-store"
AWS_REGION="eu-north-1"

# ============================
# EMAIL & SMS
# ============================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_email@gmail.com"
SMTP_PASSWORD="your_app_password"
EMAIL_FROM="noreply@wolloyewa.com"

SMS_PROVIDER="ethio_telecom"        # ethio_telecom / african_talking / twilio
SMS_API_KEY="your_sms_api_key"
SMS_SENDER_ID="WOLLOYEWA"

# ============================
# ANALYTICS & MONITORING
# ============================
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090
GRAFANA_ENABLED=True
SENTRY_DSN=""
OTEL_TRACING_ENABLED=False
OTEL_EXPORTER_ENDPOINT="http://jaeger:14268/api/traces"

# ============================
# SERVER SESSIONS
# ============================
MAX_ACTIVE_SESSIONS=15
MAX_IDLE_SESSIONS=10
SESSION_TIMEOUT_MINUTES=30
TRANSACTIONS_PER_SECOND_ACTIVE=4
TRANSACTIONS_PER_SECOND_IDLE=2

# ============================
# RATE LIMITING
# ============================
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_STRATEGY="sliding_window"

# ============================
# MULTI-TENANCY
# ============================
MULTI_TENANT_ENABLED=False
DEFAULT_TENANT_ID="public"

# ============================
# SECURITY & COMPLIANCE
# ============================
JWT_SECRET_KEY="change-this-jwt-secret-key-min-32-chars"
JWT_ALGORITHM="HS256"
JWT_EXPIRY_MINUTES=1440
CORS_ALLOWED_ORIGINS='["http://localhost:3000", "http://localhost:8000"]'
ALLOWED_HOSTS="localhost,127.0.0.1"
ENCRYPTION_KEY="your-fernet-encryption-key-32-bytes-base64"
GDPR_COMPLIANT=True
DATA_RETENTION_DAYS=365
AUDIT_LOG_ENABLED=True

# ============================
# FEATURE FLAGS
# ============================
ENABLE_PUSH_NOTIFICATIONS=True
ENABLE_WEB_APP=True
ENABLE_AI_SUPPORT_BOT=False
ENABLE_LOYALTY_PROGRAM=True
ENABLE_ESCROW_SERVICE=False
ENABLE_AB_TESTING=False

# ============================
# DATABASE MONITORING
# ============================
MONITOR_TUPLE_INSERTS=True
MONITOR_TUPLE_UPDATES=True
MONITOR_TUPLE_DELETES=True
MONITOR_BLOCK_READS=True
MONITOR_BLOCK_HITS=True
MONITOR_FETCHED_ROWS=True
MONITOR_RETURNED_ROWS=True

# ============================
# POSTGRES EXTENSIONS
# ============================
ENABLED_EXTENSIONS="foreign_data_wrappers,languages,publications,schemas,subscriptions,table_spaces"

# ============================
# EXTERNAL SERVICES
# ============================
GOOGLE_MAPS_API_KEY="your_google_maps_key"
ETHIOPIAN_HOLIDAYS_API="https://api.ethiopianholidays.com/v1"

# ============================
# CELERY (Background Tasks)
# ============================
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}
CELERY_TASK_ALWAYS_EAGER=False
CELERY_WORKER_CONCURRENCY=4

# ============================
# LOGGING
# ============================
LOG_LEVEL="INFO"
LOG_FORMAT="json"
LOG_FILE_PATH="./logs/bot_errors.log"

# ============================
# BACKUP & DISASTER RECOVERY
# ============================
BACKUP_ENABLED=True
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH="/backups"

# ============================
# DEVELOPMENT ONLY
# ============================
DEV_FAKE_PAYMENT=False
DEV_POPULATE_DUMMY_DATA=True
DEV_SKIP_MIDDLEWARES=False
# ============================
# Welcome and Greeting Messages
# ============================

msgid "welcome_message"
msgstr "🌟 እንኳን ደህና መጡ ወደ ዎሎየዋ ስቶር! የኢትዮጵያ የመጀመሪያው ዘመናዊ የኢ-ኮሜርስ ቴሌግራም ቦት።"

msgid "welcome_back_message"
msgstr "👋 እንኳን ደህና ተመለሱ! እንዴት ልረዳዎት እችላለሁ?"

msgid "help_message"
msgstr "📖 የቦት መመሪያ\n\n/start - ቦቱን ለመጀመር\n/menu - ዋና ምናሌ ለማየት\n/search - ምርቶችን ለመፈለግ\n/cart - የግዢ ቅርጫትን ለማየት\n/checkout - ግዢን ለማጠናቀቅ\n/profile - መለያዎን ለማየት\n/orders - ትዕዛዞትን ለመከታተል\n/feedback - ግብረ መልስ ለመስጠት"

